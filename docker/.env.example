# Generated by cac-docker setup — no need to edit manually.

# ── Proxy (required) ────────────────────────────────────────────────
# Share link:  ss://..., vmess://..., vless://..., trojan://...
# Compact:     ip:port  or  ip:port:user:pass
# PROXY_URI=

# ── Deploy mode (auto-detected) ─────────────────────────────────────
# DEPLOY_MODE=remote     # remote=macvlan, local=bridge

# ── Macvlan (auto-detected, remote only) ─────────────────────────────
# HOST_INTERFACE=eth0
# MACVLAN_SUBNET=192.168.1.0/24
# MACVLAN_GATEWAY=192.168.1.1
# MACVLAN_IP=192.168.1.200
# SHIM_IP=192.168.1.201

# ── Data (persistent storage) ────────────────────────────────────────
# CAC_DATA=./data      # host directory for /root and /home

# ── Optional ─────────────────────────────────────────────────────────
# SINGBOX_ENABLE=1
# DNS_SERVER=8.8.8.8
# TUN_ADDRESS=172.19.0.1/30
# TUN_MTU=9000
# DISABLE_IPV6=1
# HEALTHCHECK=1
